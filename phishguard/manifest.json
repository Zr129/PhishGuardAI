{
  "manifest_version": 3,
  "name": "PhishGuard Detector",
  "version": "1.0",
  "description": "Real-time phishing detection using behavioral and brand analysis.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs" 
  ],

  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}